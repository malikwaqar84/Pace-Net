# ─── Fixtures ─────────────────────────────────────────────────────────────────
N_S  = 16   # sleep nodes (8 channel + 8 biomarker)
N_C  = 50   # brain ROIs (reduced for testing)
N_PVS = 24  # PVS nodes
N_E  = 100  # edges
B    = 4    # batch size
D_S  = 128  # sleep hidden dim
D_C  = 256  # brain hidden dim
D_G  = 64   # glymphatic hidden dim


# ─── SFG Tests ────────────────────────────────────────────────────────────────
class TestSFGTransformer:
    def test_output_shape(self):
        model = SFGTransformer(node_feat_dim=32, hidden_dim=D_S,
                               n_layers=2, n_heads=4)
        x = torch.randn(N_S, 32)
        edge_index = torch.randint(0, N_S, (2, N_E))
        edge_attr  = torch.rand(N_E)
        band_ids   = torch.randint(0, 5, (N_E,))
        stage_ids  = torch.randint(0, 5, (N_S,))
        h = model(x, edge_index, edge_attr, band_ids, stage_ids)
        assert h.shape == (N_S, D_S), f"Expected ({N_S},{D_S}), got {h.shape}"

    def test_no_nan(self):
        model = SFGTransformer(node_feat_dim=32, hidden_dim=D_S,
                               n_layers=2, n_heads=4)
        x = torch.randn(N_S, 32)
        edge_index = torch.randint(0, N_S, (2, N_E))
        edge_attr  = torch.rand(N_E)
        band_ids   = torch.randint(0, 5, (N_E,))
        stage_ids  = torch.randint(0, 5, (N_S,))
        h = model(x, edge_index, edge_attr, band_ids, stage_ids)
        assert not torch.isnan(h).any(), "NaN values in SFG output"


# ─── GPG Tests ────────────────────────────────────────────────────────────────
class TestGPGTransformer:
    def test_output_shapes(self):
        model = GPGTransformer(node_feat_dim=12, hidden_dim=D_G,
                               n_layers=2, n_heads=2,
                               n_pvs_nodes=N_PVS, n_brain_rois=N_C)
        x = torch.randn(N_PVS, 12)
        edge_index = torch.randint(0, N_PVS, (2, 50))
        w_struct   = torch.rand(50)
        z_swa      = torch.rand(B, 1)
        h_G, G_glyph, z_G = model(x, edge_index, w_struct, z_swa)
        assert h_G.shape    == (N_PVS, D_G)
        assert G_glyph.shape == (N_PVS, N_C)
        assert z_G.shape[1] == D_G

    def test_swa_gating(self):
        """SWA gate values should be in (0, 1) — sigmoid output."""
        gate = SWAGatingModule(swa_dim=1, hidden_dim=16)
        w = torch.rand(50)
        z_swa = torch.rand(B, 1)
        w_gated = gate(w, z_swa)
        assert (w_gated >= 0).all() and (w_gated <= w.max() + 1e-4).all()


# ─── BCG Tests ────────────────────────────────────────────────────────────────
class TestBCGTransformer:
    def test_output_shape(self):
        model = BCGTransformer(node_feat_dim=20, hidden_dim=D_C,
