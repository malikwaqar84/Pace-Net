# ─── CGAT Tests ───────────────────────────────────────────────────────────────
class TestCGAT:
    def test_cross_attention_shape(self):
        attn = GlymphaticGatedCrossAttention(
            sleep_dim=D_S, brain_dim=D_S, n_heads=4)
        H_S = torch.randn(N_S, D_S)
        H_C = torch.randn(N_C, D_S)
        G   = torch.rand(N_S, N_C)
        H_S_new, attn_map = attn(H_S, H_C, G)
        assert H_S_new.shape == (N_S, D_S)
        assert attn_map.shape == (N_S, N_C)

    def test_ablation_no_gating(self):
        """Without gating, attention should differ from gated version."""
        attn = GlymphaticGatedCrossAttention(
            sleep_dim=D_S, brain_dim=D_S, n_heads=4)
        H_S = torch.randn(N_S, D_S)
        H_C = torch.randn(N_C, D_S)
        G   = torch.rand(N_S, N_C) * 0.1  # Very sparse gate

        with torch.no_grad():
            h_gated, _   = attn(H_S, H_C, G, use_glymphatic_gating=True)
            h_ungated, _ = attn(H_S, H_C, G, use_glymphatic_gating=False)

        # Should not be equal when gate is very sparse
        assert not torch.allclose(h_gated, h_ungated, atol=1e-3)

    def test_cgat_fusion_shape(self):
        fusion = CGATFusion(sleep_dim=D_S, brain_dim=D_C, glyph_dim=D_G,
                            out_dim=D_C, n_heads=4)
        H_S = torch.randn(N_S, D_S)
        H_C = torch.randn(N_C, D_C)
        H_G = torch.randn(N_PVS, D_G)
        G   = torch.rand(N_S, N_C)
        z_fused, attn_map = fusion(H_S, H_C, H_G, G)
        assert z_fused.shape == (D_C,)
        assert attn_map.shape == (N_S, N_C)


# ─── DiffPool Tests ───────────────────────────────────────────────────────────
class TestDiffPool:
    def test_output_shape(self):
        pool = HierarchicalDiffPool(in_dim=D_C, hidden_dim=D_C,
                                    n_clusters_1=7, n_clusters_2=1)
        x   = torch.randn(B, N_C, D_C)
        adj = torch.rand(B, N_C, N_C)
        z_C, loss = pool(x, adj)
        assert z_C.shape == (B, D_C), f"Expected ({B},{D_C}), got {z_C.shape}"
        assert not torch.isnan(z_C).any()
        assert loss.item() >= 0


# ─── Loss Tests ───────────────────────────────────────────────────────────────
class TestLosses:
    def test_focal_loss(self):
        fl = FocalLoss(gamma=2.0)
        logits  = torch.randn(B, 3)
        targets = torch.randint(0, 3, (B,))
        loss = fl(logits, targets)
        assert loss.item() > 0
        assert not torch.isnan(loss)

    def test_composite_loss(self):
        criterion = PACENetLoss(lambda_ce=1.0, lambda_mse=0.4,
                                lambda_struct=0.6, lambda_cf=0.2)
        logits    = torch.randn(B, 3)
        targets   = torch.randint(0, 3, (B,))
        mmse_pred = torch.rand(B, 1)
        mmse_true = torch.rand(B, 1) * 30
        z_G_pred  = torch.randn(B, 64)
        z_G_obs   = torch.randn(B, 64)
        z_C_pred  = torch.randn(B, 256)
        z_C_obs   = torch.randn(B, 256)
        cf_z_C    = torch.randn(B, 128)
        cn_mean   = torch.zeros(128)

        ld = criterion(logits, targets, mmse_pred, mmse_true,
                       z_G_pred, z_G_obs, z_C_pred, z_C_obs,
                       cf_z_C, cn_mean)
        assert 'total' in ld
        assert 'ce' in ld
        assert ld['total'].item() > 0


# ─── Metrics Tests ────────────────────────────────────────────────────────────
class TestMetrics:
    def test_perfect_prediction(self):
        y = np.array([0, 1, 2, 0, 1, 2])
        m = compute_metrics(y, y)
        assert m['accuracy'] == 100.0
        assert m['mcc'] == pytest.approx(1.0, abs=1e-6)
        assert m['jaccard'] == pytest.approx(1.0, abs=1e-6)
        assert m['cohen_kappa'] == pytest.approx(1.0, abs=1e-6)

    def test_random_prediction(self):
        np.random.seed(42)
        y_true = np.random.randint(0, 3, 100)
        y_pred = np.random.randint(0, 3, 100)
        m = compute_metrics(y_true, y_pred)
        # Random should be ~33% accuracy, MCC near 0
        assert 0 < m['accuracy'] < 100
        assert -1 <= m['mcc'] <= 1


